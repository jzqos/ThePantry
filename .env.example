# Copy this file to .env and fill in your values before running docker compose.

# ── Authentication ────────────────────────────────────────────────────────────
# Password required to log in. Change before exposing to any network.
PASSWORD=changeme

# ── Timezone ──────────────────────────────────────────────────────────────────
# IANA timezone name — controls how all timestamps are displayed in the app.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Zurich

# ── OpenFoodFacts ─────────────────────────────────────────────────────────────
# Base URL for product lookups. Default is the global instance.
OPENFOODFACTS_ADDRESS=https://world.openfoodfacts.net/
