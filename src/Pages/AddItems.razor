@page "/add-items"
@using MediatR
@using ThePantry.Application.Commands
@using ThePantry.Application.Queries
@using ThePantry.Application.Services
@using ThePantry.Services
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IMediator Mediator
@inject ILogger<AddItems> Logger
@inject ToastService ToastService
@inject IJSRuntime JS
@inject AppSettingsService AppSettingsService
@inject IConfiguration Configuration
@inject NavigationManager NavigationManager

<PageTitle>Add Items - The Pantry</PageTitle>

<h1>Add Inventory Items</h1>

<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "scan" ? "active" : "")" @onclick="SetTabScan">
            Scanner
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "manual" ? "active" : "")" @onclick="SetTabManual">
            Manual Entry
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "csv" ? "active" : "")" @onclick="SetTabCsv">
            CSV Upload
        </button>
    </li>
</ul>

@if (activeTab == "scan")
{
    <div class="card">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label fw-semibold mb-1">Scan into location</label>
                <select class="form-select" @bind="selectedCategory">
                    @if (availableCategories != null)
                    {
                        @foreach (var cat in availableCategories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                </select>
            </div>

            <div id="reader" style="width: 100%; max-width: 600px; margin: 0 auto; border-radius: 8px; overflow: hidden;"></div>

            @* Unknown-item card — only shown when a barcode wasn't found in OpenFoodFacts *@
            @if (unknownScanPending && lastQueuedItemId.HasValue)
            {
                <div class="card border-warning mt-3">
                    <div class="card-body py-2 px-3">
                        <div class="fw-semibold mb-2">
                            <span class="oi oi-question-mark me-1 text-warning"></span>
                            Unknown product — queued for AI recognition
                        </div>

                        @if (frontPhotoAdded)
                        {
                            <div class="alert alert-success py-1 small mb-2">Front photo attached — label will be recognised automatically.</div>
                        }
                        else
                        {
                            <button class="btn btn-warning btn-sm w-100 mb-2" @onclick="CaptureFrontPhoto" disabled="@capturingFrontPhoto">
                                @if (capturingFrontPhoto)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <span class="oi oi-camera me-1"></span>
                                }
                                Capture front label photo (optional)
                            </button>
                        }

                        <button class="btn btn-outline-secondary btn-sm w-100" @onclick="DismissUnknownCard">
                            <span class="oi oi-arrow-right me-1"></span> Continue scanning
                        </button>
                    </div>
                </div>
            }

            <div class="mt-3">
                <div class="row g-2">
                    <div class="col-10">
                        <input type="text" class="form-control" placeholder="Enter UPC code manually..." @bind="scanUpc" @bind:event="oninput" />
                    </div>
                    <div class="col-2">
                        <button type="button" class="btn btn-primary w-100" @onclick="QueueScan" disabled="@string.IsNullOrWhiteSpace(scanUpc)">
                            Scan
                        </button>
                    </div>
                </div>
            </div>
            
            <hr />
            
            <h5>Recent Scans</h5>
            @if (recentScans.Any())
            {
                <ul class="list-group">
                    @foreach (var scan in recentScans)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>
                                <strong>@scan.Upc</strong>
                                @if (!string.IsNullOrEmpty(scan.ProductName))
                                {
                                    <span class="text-muted"> - @scan.ProductName</span>
                                }
                            </span>
                            <span class="badge bg-@GetStatusBadge(scan.Status)">
                                @scan.Status
                            </span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No recent scans</p>
            }
        </div>
    </div>
}
else if (activeTab == "manual")
{
    <div class="card">
        <div class="card-body">
            <EditForm Model="manualItem" OnValidSubmit="AddManualItem">
                <DataAnnotationsValidator />
                <ValidationSummary />
                
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name *</label>
                        <InputText class="form-control" @bind-Value="manualItem.Name" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Category</label>
                        <InputSelect class="form-select" @bind-Value="manualItem.Category">
                            @if (availableCategories != null)
                            {
                                @foreach (var cat in availableCategories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            }
                        </InputSelect>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <InputText class="form-control" @bind-Value="manualItem.Description" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">On Hand Count</label>
                        <InputNumber class="form-control" @bind-Value="manualItem.OnHandCount" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Minimum Threshold</label>
                        <InputNumber class="form-control" @bind-Value="manualItem.MinimumThreshold" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Shelf Life (Days)</label>
                        <InputNumber class="form-control" @bind-Value="manualItem.ShelfLifeDays" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Use Within (Days)</label>
                        <InputNumber class="form-control" @bind-Value="manualItem.UseWithinDays" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">SKUs (comma separated)</label>
                        <InputText class="form-control" @bind-Value="manualItem.Skus" placeholder="e.g. 123456, 789012" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Image URL</label>
                        <InputText class="form-control" @bind-Value="manualItem.ImageUrl" placeholder="https://example.com/image.jpg" />
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary mt-3">Add Item</button>
            </EditForm>
        </div>
    </div>
}
else if (activeTab == "csv")
{
    <div class="card">
        <div class="card-body">
            <p>Upload a CSV file with the following columns:</p>
            <code>Name, Description, Category, OnHandCount, MinimumThreshold, Skus (semicolon separated)</code>
            
            <div class="mt-3">
                <InputFile OnChange="HandleCsvUpload" accept=".csv" class="form-control" />
            </div>
            
            @if (!string.IsNullOrEmpty(csvMessage))
            {
                <div class="alert @(csvSuccess ? "alert-success" : "alert-danger") mt-3">
                    @csvMessage
                </div>
            }
        </div>
    </div>
}

@code {
    private string activeTab = "scan";
    private ManualItemModel manualItem = new();
    private string csvMessage = "";
    private bool csvSuccess = false;
    private string scanUpc = "";
    private List<ScanQueueItemDto> recentScans = new();
    private DotNetObjectReference<AddItems>? objRef;
    private bool isScannerRunning = false;

    private string selectedCategory = "Pantry";

    // Unknown-item card state (shown only when barcode not found in OpenFoodFacts)
    private bool unknownScanPending = false;
    private int? lastQueuedItemId;           // LabelQueueItem.Id for the pending unknown item
    private bool isScanning = false;         // prevents re-entrant HandleBarcodeDetected
    private bool labelRecognitionAvailable;
    private bool frontPhotoAdded;
    private bool capturingFrontPhoto;
    
    private async Task SetTabManual()
    {
        await StopScanner();
        activeTab = "manual";
    }
    
    private async Task SetTabCsv()
    {
        await StopScanner();
        activeTab = "csv";
    }
    
    private async Task SetTabScan()
    {
        activeTab = "scan";
        await StartScanner();
    }
    
    private class ManualItemModel
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string Category { get; set; } = "Pantry";
        public int OnHandCount { get; set; } = 1;
        public int MinimumThreshold { get; set; } = 1;
        public int ShelfLifeDays { get; set; } = 30;
        public int UseWithinDays { get; set; } = 7;
        public string? ImageUrl { get; set; }
        public string? Skus { get; set; }
    }
    
    private List<string>? availableCategories;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecentScans();
        var provider = await AppSettingsService.GetAsync("LLM_PROVIDER");
        labelRecognitionAvailable = !string.IsNullOrWhiteSpace(provider);
        availableCategories = await Mediator.Send(new GetCategoriesQuery());
        if (availableCategories.Any()) selectedCategory = availableCategories.First();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && activeTab == "scan")
        {
            await StartScanner();
        }
    }

    private async Task StartScanner()
    {
        if (isScannerRunning) return;
        
        try
        {
            objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("barcodeScanner.start", objRef, "reader");
            isScannerRunning = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to start scanner");
            await ToastService.ShowError("Could not access camera. Please ensure permissions are granted.");
        }
    }

    private async Task StopScanner()
    {
        if (!isScannerRunning) return;
        
        try
        {
            // Check if we can still call JS (prevents error on page navigation/dispose)
            await JS.InvokeVoidAsync("barcodeScanner.stop");
            isScannerRunning = false;
        }
        catch (JSDisconnectedException)
        {
            // Ignore disconnection errors during disposal
            isScannerRunning = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to stop scanner");
        }
    }

    [JSInvokable]
    public async Task HandleBarcodeDetected(string code, string? imageData)
    {
        // Block re-entrant calls while processing the current scan
        if (isScanning) return;
        // Also block if the unknown-item card is showing (user must dismiss it first)
        if (unknownScanPending) return;
        isScanning = true;

        try
        {
            Logger.LogInformation("Barcode detected: {Code}", code);

            var result = await Mediator.Send(new IncrementInventoryByScannerCommand(code, 1, selectedCategory));

            var isUnknown = result.Name.StartsWith("Unknown Product (");

            if (isUnknown && labelRecognitionAvailable)
            {
                // Queue for LLM label recognition, delete the placeholder inventory item
                var storagePath = Configuration["ScanStoragePath"] ?? "/uploads/scans";
                lastQueuedItemId = await Mediator.Send(new QueueLabelScanCommand(code, imageData, selectedCategory, storagePath));
                try { await Mediator.Send(new DeleteInventoryItemCommand(result.Id)); } catch { }

                unknownScanPending = true;
                frontPhotoAdded = false;
                // Scanner stays paused (_paused=true set in JS callback); user dismisses card to resume
            }
            else
            {
                // Known item: release the pause set in the JS callback, starting a fresh 1s cooldown.
                // This guarantees exactly one add per item regardless of how long the DB/API call took.
                try { await JS.InvokeVoidAsync("barcodeScanner.resetCooldown"); } catch { }
            }

            await LoadRecentScans();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error processing barcode {Code}", code);
            await ToastService.ShowError("Failed to process scan.");
        }
        finally
        {
            isScanning = false;
        }

        StateHasChanged();
    }

    private async Task DismissUnknownCard()
    {
        unknownScanPending = false;
        lastQueuedItemId = null;
        frontPhotoAdded = false;
        StateHasChanged();
        try { await JS.InvokeVoidAsync("barcodeScanner.resetCooldown"); } catch { }
    }

    private async Task CaptureFrontPhoto()
    {
        if (!lastQueuedItemId.HasValue) return;
        capturingFrontPhoto = true;
        StateHasChanged();

        try
        {
            var frontImage = await JS.InvokeAsync<string?>("barcodeScanner.captureFrame", "reader");
            if (string.IsNullOrWhiteSpace(frontImage))
            {
                await ToastService.ShowError("Could not capture image. Try again.");
                return;
            }

            var storagePath = Configuration["ScanStoragePath"] ?? "/uploads/scans";
            var ok = await Mediator.Send(new AppendLabelPhotoCommand(lastQueuedItemId.Value, frontImage, storagePath));
            frontPhotoAdded = ok;
            if (!ok) await ToastService.ShowError("Could not attach photo.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error capturing front label photo");
            await ToastService.ShowError("Failed to capture photo.");
        }
        finally
        {
            capturingFrontPhoto = false;
            StateHasChanged();
        }
    }

    
    private async Task LoadRecentScans()
    {
        try
        {
            recentScans = await Mediator.Send(new GetScanQueueQuery());
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading recent scans");
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopScanner();
        objRef?.Dispose();
    }
    
    private async Task AddManualItem()
    {
        try
        {
            var skuList = manualItem.Skus?.Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(s => s.Trim())
                .ToList();

            await Mediator.Send(new AddInventoryItemCommand(
                manualItem.Name,
                manualItem.Description,
                manualItem.Category,
                manualItem.OnHandCount,
                manualItem.MinimumThreshold,
                manualItem.ShelfLifeDays,
                manualItem.UseWithinDays,
                manualItem.ImageUrl,
                skuList
            ));

            await ToastService.ShowSuccess($"Added {manualItem.Name} to inventory");
            manualItem = new(); // Reset form
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error adding manual item");
            await ToastService.ShowError("Error adding item: " + ex.Message);
        }
    }
    
    private async Task HandleCsvUpload(InputFileChangeEventArgs e)
    {
        csvMessage = "Uploading and processing...";
        csvSuccess = false;
        int successCount = 0;
        int errorCount = 0;

        try
        {
            using var stream = e.File.OpenReadStream();
            using var reader = new System.IO.StreamReader(stream);
            
            // Skip header
            var header = await reader.ReadLineAsync();
            
            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (string.IsNullOrWhiteSpace(line)) continue;

                var parts = line.Split(',');
                if (parts.Length < 1) continue;

                try
                {
                    var name = parts[0].Trim();
                    var description = parts.Length > 1 ? parts[1].Trim() : null;
                    var category = parts.Length > 2 ? parts[2].Trim() : "Pantry";
                    int.TryParse(parts.Length > 3 ? parts[3].Trim() : "1", out int onHand);
                    int.TryParse(parts.Length > 4 ? parts[4].Trim() : "1", out int min);
                    var skusRaw = parts.Length > 5 ? parts[5].Trim() : null;
                    var skus = skusRaw?.Split(';', StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim()).ToList();

                    await Mediator.Send(new AddInventoryItemCommand(
                        name, description, category, onHand, min, 30, 7, null, skus
                    ));
                    successCount++;
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Error processing CSV line: {Line}", line);
                    errorCount++;
                }
            }

            csvSuccess = true;
            csvMessage = $"Successfully imported {successCount} items. Errors: {errorCount}";
            await ToastService.ShowSuccess($"Imported {successCount} items");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error uploading CSV");
            csvSuccess = false;
            csvMessage = "Error uploading CSV: " + ex.Message;
            await ToastService.ShowError("CSV upload failed");
        }
    }
    
    private async Task QueueScan()
    {
        try
        {
            await Mediator.Send(new QueueScanCommand(scanUpc.Trim(), Category: selectedCategory));
            await ToastService.ShowInfo($"UPC {scanUpc} queued for processing");
            scanUpc = "";
            await LoadRecentScans();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error queueing scan");
            await ToastService.ShowError("Error queueing scan: " + ex.Message);
        }
    }
    
    private string GetStatusBadge(Domain.ScanStatus status) => status switch
    {
        Domain.ScanStatus.Pending => "secondary",
        Domain.ScanStatus.Processing => "info",
        Domain.ScanStatus.Complete => "success",
        Domain.ScanStatus.Failed => "danger",
        _ => "secondary"
    };
}