@page "/scan"
@page "/scan/{Mode}"
@using MediatR
@using ThePantry.Application.Commands
@using ThePantry.Application.Queries
@using ThePantry.Application.Services
@using ThePantry.Services
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IMediator Mediator
@inject ILogger<Scan> Logger
@inject ToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject ILabelRecognitionService LabelRecognition
@inject AppSettingsService AppSettingsService
@inject IConfiguration Configuration

<PageTitle>Scan - The Pantry</PageTitle>

<div class="container-fluid p-0">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Inventory Scanner</h4>
                <div class="btn-group" role="group" aria-label="Scan Mode">
                    <button type="button" class="btn @(CurrentMode == "add" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetMode("add")'>
                        <span class="oi oi-plus me-1"></span> Add
                    </button>
                    <button type="button" class="btn @(CurrentMode == "open" ? "btn-warning" : "btn-outline-warning")" @onclick='() => SetMode("open")'>
                        <span class="oi oi-external-link me-1"></span> Open
                    </button>
                    <button type="button" class="btn @(CurrentMode == "use" ? "btn-danger" : "btn-outline-danger")" @onclick='() => SetMode("use")'>
                        <span class="oi oi-minus me-1"></span> Use
                    </button>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold mb-1">Location</label>
                <select class="form-select" @bind="selectedCategory">
                    @if (availableCategories != null)
                    {
                        @foreach (var cat in availableCategories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                </select>
            </div>

            <div class="scanner-container position-relative bg-dark rounded overflow-hidden mb-3" style="min-height: 300px;">
                <div id="reader" style="width: 100%;"></div>
                @if (isProcessing)
                {
                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50" style="z-index: 10;">
                        <div class="spinner-border text-light" role="status">
                            <span class="visually-hidden">Processing...</span>
                        </div>
                    </div>
                }
            </div>

            <div class="input-group mb-3">
                <input type="text" class="form-control" placeholder="Enter UPC manually..." @bind="manualUpc" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                <button class="btn btn-secondary" type="button" @onclick="ProcessManualUpc" disabled="@(string.IsNullOrWhiteSpace(manualUpc) || isProcessing)">
                    Process
                </button>
            </div>

            @if (lastQueuedItemId.HasValue)
            {
                <div class="card border-warning mb-3 animate-fade-in">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-semibold text-warning-emphasis">
                                <span class="oi oi-camera me-1"></span> Add front label photo
                            </span>
                            <button type="button" class="btn-close btn-sm" @onclick="DismissFrontPhotoCard"></button>
                        </div>
                        <p class="small text-muted mb-2">
                            Point the camera at the <strong>front of the product</strong> where the name is printed, then press the button.
                        </p>
                        @if (frontPhotoAdded)
                        {
                            <div class="alert alert-success py-1 small mb-0">Front photo added — will be included in recognition.</div>
                        }
                        else
                        {
                            <button class="btn btn-warning btn-sm w-100" @onclick="CaptureFrontPhoto" disabled="@capturingFrontPhoto">
                                @if (capturingFrontPhoto)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <span class="oi oi-camera me-1"></span> Capture front label photo
                            </button>
                        }
                    </div>
                </div>
            }

            @if (lastProcessedItem != null)
            {
                <div class="card border-@GetAlertColor() mb-3 animate-fade-in">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex align-items-center mb-2">
                            @if (!string.IsNullOrEmpty(lastProcessedItem.ImageUrl))
                            {
                                <img src="@lastProcessedItem.ImageUrl" alt="@lastProcessedItem.Name" class="rounded me-3" style="width: 48px; height: 48px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="rounded me-3 bg-secondary d-flex align-items-center justify-content-center text-white flex-shrink-0" style="width: 48px; height: 48px;">
                                    <span class="oi oi-image"></span>
                                </div>
                            }
                            <div class="flex-grow-1">
                                <div class="fw-bold">@lastProcessedItem.Name</div>
                                <div class="small text-muted">
                                    @if (CurrentMode == "add") { <span>Added to @lastProcessedItem.Category — count: @lastProcessedItem.OnHandCount</span> }
                                    else if (CurrentMode == "open") { <span>Opened — @lastProcessedItem.OnHandCount remaining sealed</span> }
                                    else { <span>Used — @lastProcessedItem.OnHandCount remaining</span> }
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-success btn-sm flex-grow-1" @onclick="ConfirmScan">
                                <span class="oi oi-check me-1"></span> OK
                            </button>
                            <button class="btn btn-outline-secondary btn-sm flex-grow-1" @onclick="RetryScan">
                                <span class="oi oi-reload me-1"></span> Wrong item — retry
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Label recognition modal -->
@if (showLabelModal)
{
    <div class="modal fade show" style="display:block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Unknown Product — Label Recognition</h5>
                    <button type="button" class="btn-close" @onclick="DismissLabelModal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">
                        This barcode was not found in the product database (it may be a store-reduced item).
                        Fill in the details below to add it to your inventory.
                        To enable automatic label recognition via photo, add an Anthropic API key in Settings.
                    </p>

                    @if (labelError != null)
                    {
                        <div class="alert alert-warning small">@labelError</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Product name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="labelName" placeholder="e.g. Chicken Breast" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Species / animal <span class="text-muted small">(optional)</span></label>
                        <input type="text" class="form-control" @bind="labelSpecies" placeholder="e.g. Chicken" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Weight <span class="text-muted small">(optional)</span></label>
                        <input type="text" class="form-control" @bind="labelWeight" placeholder="e.g. 500g" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Shelf life (days)</label>
                        <input type="number" class="form-control" @bind="labelShelfLifeDays" min="1" max="90" />
                        <div class="form-text">Use up to 90 days for frozen items.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <select class="form-select" @bind="labelCategory">
                            @if (availableCategories != null)
                            {
                                @foreach (var cat in availableCategories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="DismissLabelModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="ConfirmLabelItem" disabled="@string.IsNullOrWhiteSpace(labelName)">Add to Inventory</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<style>
    .scanner-container #reader video {
        object-fit: cover;
        width: 100% !important;
        height: 100% !important;
        min-height: 300px;
    }
    .animate-fade-in {
        animation: fadeIn 0.3s ease-in-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [Parameter] public string? Mode { get; set; }
    private string CurrentMode => (Mode?.ToLower() ?? "add");
    private string manualUpc = "";
    private bool isProcessing = false;
    private ThePantry.Domain.InventoryItem? lastProcessedItem;
    private DotNetObjectReference<Scan>? objRef;
    private bool isScannerRunning = false;

    private List<string>? availableCategories;
    private string selectedCategory = "Pantry";

    // Front-photo card state (shown after a label is queued)
    private int? lastQueuedItemId;
    private bool frontPhotoAdded = false;
    private bool capturingFrontPhoto = false;

    // Label recognition modal state
    private bool showLabelModal = false;
    private bool labelRecognitionAvailable = false;
    private string? labelError;
    private string pendingUpc = "";
    private string labelName = "";
    private string? labelSpecies;
    private string? labelWeight;
    private int labelShelfLifeDays = 30;
    private string labelCategory = "Refrigerator";
    private LabelRecognitionResult? labelResult;

    protected override async Task OnInitializedAsync()
    {
        availableCategories = await Mediator.Send(new GetCategoriesQuery());
        if (availableCategories.Any()) selectedCategory = availableCategories.First();
        var provider = await AppSettingsService.GetAsync("LLM_PROVIDER");
        labelRecognitionAvailable = !string.IsNullOrWhiteSpace(provider);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await StartScanner();
        }
    }

    private void SetMode(string newMode)
    {
        NavigationManager.NavigateTo($"/scan/{newMode}");
        lastProcessedItem = null;
    }

    private async Task StartScanner()
    {
        if (isScannerRunning) return;
        try
        {
            objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("barcodeScanner.start", objRef, "reader");
            isScannerRunning = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to start scanner");
            await ToastService.ShowError("Could not access camera. Please ensure permissions are granted.");
        }
    }

    private async Task StopScanner()
    {
        if (!isScannerRunning) return;
        try
        {
            await JS.InvokeVoidAsync("barcodeScanner.stop");
            isScannerRunning = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to stop scanner");
        }
    }

    [JSInvokable]
    public async Task HandleBarcodeDetected(string code, string? imageData)
    {
        if (isProcessing) return;
        await ProcessUpc(code);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(manualUpc))
        {
            await ProcessManualUpc();
        }
    }

    private async Task ProcessManualUpc()
    {
        var upc = manualUpc;
        manualUpc = "";
        await ProcessUpc(upc);
    }

    private async Task ProcessUpc(string upc)
    {
        isProcessing = true;
        StateHasChanged();

        try
        {
            ThePantry.Domain.InventoryItem? result = null;

            switch (CurrentMode)
            {
                case "add":
                    result = await Mediator.Send(new IncrementInventoryByScannerCommand(upc, 1, selectedCategory));
                    if (result.Name.StartsWith("Unknown Product ("))
                    {
                        if (labelRecognitionAvailable)
                        {
                            await EnqueueLabelScan(upc, result);
                            return;
                        }
                        else
                        {
                            await PromptLabelRecognitionManual(upc, result);
                            return;
                        }
                    }
                    await ToastService.ShowSuccess($"Added {result.Name}");
                    lastQueuedItemId = null; // clear front-photo card when a new item is successfully added
                    break;
                case "open":
                    result = await Mediator.Send(new MarkAsOpenedByScannerCommand(upc));
                    await ToastService.ShowInfo($"Updated {result?.Name}");
                    break;
                case "use":
                    result = await Mediator.Send(new DecrementInventoryByScannerCommand(upc));
                    await ToastService.ShowWarning($"Used {result?.Name}");
                    break;
            }

            lastProcessedItem = result;
            // Pause the scanner so the result card stays visible until user confirms
            await JS.InvokeVoidAsync("barcodeScanner.pauseScanning");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error processing UPC {Upc} in mode {Mode}", upc, CurrentMode);
            await ToastService.ShowError("Failed to process item.");
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task EnqueueLabelScan(string upc, ThePantry.Domain.InventoryItem? placeholderItem)
    {
        // Remove the placeholder item created by the scanner command
        if (placeholderItem != null)
        {
            try { await Mediator.Send(new DeleteInventoryItemCommand(placeholderItem.Id)); }
            catch { /* best effort */ }
        }

        // Capture current frame for the queue
        string? imageData = null;
        try { imageData = await JS.InvokeAsync<string?>("barcodeScanner.captureFrame", "reader"); }
        catch { /* best effort */ }

        var storagePath = Configuration["ScanStoragePath"] ?? "uploads/scans";
        lastQueuedItemId = await Mediator.Send(new QueueLabelScanCommand(upc, imageData, selectedCategory, storagePath));
        frontPhotoAdded = false;

        await ToastService.ShowInfo($"Label queued ({upc}) — add a front photo or continue scanning!");
        isProcessing = false;
        StateHasChanged();
    }

    private async Task CaptureFrontPhoto()
    {
        if (!lastQueuedItemId.HasValue) return;
        capturingFrontPhoto = true;
        StateHasChanged();

        try
        {
            var imageData = await JS.InvokeAsync<string?>("barcodeScanner.captureFrame", "reader");
            if (string.IsNullOrWhiteSpace(imageData))
            {
                await ToastService.ShowError("Could not capture image. Try again.");
                return;
            }

            var storagePath = Configuration["ScanStoragePath"] ?? "uploads/scans";
            var ok = await Mediator.Send(new AppendLabelPhotoCommand(lastQueuedItemId.Value, imageData, storagePath));
            if (ok)
            {
                frontPhotoAdded = true;
                await ToastService.ShowSuccess("Front photo added — the item will be re-evaluated.");
            }
            else
            {
                await ToastService.ShowError("Could not attach photo. The queue item may have already been processed.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error capturing front label photo");
            await ToastService.ShowError("Failed to capture photo.");
        }
        finally
        {
            capturingFrontPhoto = false;
            StateHasChanged();
        }
    }

    private void DismissFrontPhotoCard()
    {
        lastQueuedItemId = null;
        frontPhotoAdded = false;
    }

    private async Task PromptLabelRecognitionManual(string upc, ThePantry.Domain.InventoryItem? placeholderItem)
    {
        // Remove the placeholder "Unknown Product" item that was auto-created
        if (placeholderItem != null)
        {
            try { await Mediator.Send(new DeleteInventoryItemCommand(placeholderItem.Id)); }
            catch { /* best effort */ }
        }

        pendingUpc = upc;
        labelName = "";
        labelSpecies = null;
        labelWeight = null;
        labelShelfLifeDays = 30;
        labelCategory = selectedCategory;
        labelResult = null;
        labelError = null;
        showLabelModal = true;
        isProcessing = false;
        StateHasChanged();
    }

    private async Task ConfirmLabelItem()
    {
        if (string.IsNullOrWhiteSpace(labelName)) return;

        try
        {
            var result = await Mediator.Send(new AddItemFromLabelCommand(
                pendingUpc, labelName.Trim(), labelSpecies?.Trim(), labelWeight?.Trim(), labelCategory, labelShelfLifeDays));
            lastProcessedItem = result;
            await ToastService.ShowSuccess($"Added {result.Name}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error adding label item");
            await ToastService.ShowError("Failed to add item.");
        }

        DismissLabelModal();
    }

    private void DismissLabelModal()
    {
        showLabelModal = false;
        StateHasChanged();
    }

    private string GetAlertColor() => CurrentMode switch
    {
        "add"  => "success",
        "open" => "warning",
        "use"  => "danger",
        _      => "info"
    };

    private async Task ConfirmScan()
    {
        lastProcessedItem = null;
        // Resume the scanner cooldown so the next item can be scanned immediately
        await JS.InvokeVoidAsync("barcodeScanner.resetCooldown");
        StateHasChanged();
    }

    private async Task RetryScan()
    {
        // Undo the last action if possible, then clear the result
        if (lastProcessedItem != null && CurrentMode == "add")
        {
            try { await Mediator.Send(new DecrementInventoryCommand(lastProcessedItem.Id)); }
            catch { /* best effort */ }
        }
        else if (lastProcessedItem != null && CurrentMode == "use")
        {
            try { await Mediator.Send(new IncrementInventoryCommand(lastProcessedItem.Id)); }
            catch { /* best effort */ }
        }
        lastProcessedItem = null;
        await JS.InvokeVoidAsync("barcodeScanner.resetCooldown");
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        await StopScanner();
        objRef?.Dispose();
    }
}
